# VS Agent
AGENT_ENDPOINT=https://your-ngrok-domain.ngrok-free.dev
AGENT_LABEL=Twitter Bot
AGENT_INVITATION_BASE_URL=https://hologram.zone
AGENT_INVITATION_IMAGE_URL=
ANONCREDS_SERVICE_BASE_URL=
USE_CORS=true
EVENTS_BASE_URL=http://chatbot:3000
VS_AGENT_ADMIN_URL=http://vs-agent:3000

# App
APP_PORT=3000
LOG_LEVEL=4

# LLM — supports OpenAI, Anthropic, Ollama, or OpenRouter (OpenAI-compatible)
LLM_PROVIDER=openai
OPENAI_API_KEY=your-api-key
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=meta-llama/llama-3.1-8b-instruct:free
OPENAI_TEMPERATURE=0.8
OPENAI_MAX_TOKENS=500

# Memory
AGENT_MEMORY_BACKEND=redis
AGENT_MEMORY_WINDOW=8
REDIS_URL=redis://redis:6379
REDIS_HOST=redis

# Database
POSTGRES_HOST=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB_NAME=chatbot

# RAG (optional)
RAG_PROVIDER=vectorstore
RAG_DOCS_PATH=./docs
RAG_REMOTE_URLS=
VECTOR_STORE=redis
VECTOR_INDEX_NAME=agent-ia
PINECONE_API_KEY=

# LLM Tools (optional)
LLM_TOOLS_CONFIG=

# Twitter API
TWITTER_APP_KEY=your-twitter-app-key
TWITTER_APP_SECRET=your-twitter-app-secret
TWITTER_ACCESS_TOKEN=your-twitter-access-token
TWITTER_ACCESS_SECRET=your-twitter-access-secret
TWITTER_HANDLE=your-twitter-handle
DAILY_POST_BUDGET=17

# Auth (leave empty to disable — needs trust infra deployment)
CREDENTIAL_DEFINITION_ID=

# Stats (disabled by default)
VS_AGENT_STATS_ENABLED=false

# Brand voice / System prompt
AGENT_PROMPT=You are a Twitter/X social media manager. You help users compose, review, and publish tweets. Be concise, creative, and match the brand voice. When generating tweet drafts, always provide exactly 2 different options with different angles on the topic. Each tweet must be under 280 characters.
